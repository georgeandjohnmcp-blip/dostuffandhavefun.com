---
import { buildFeaturedVideos } from "../../data/site.js";
import generatedVideos from "../../data/videos.generated.json";
import "../../styles/global.css";

const videos = buildFeaturedVideos(generatedVideos);
const hasConnectedVideos = Array.isArray(generatedVideos) && generatedVideos.length > 0;
const pageTitle = "Video Library | Do Stuff & Have Fun";
const pageDescription =
  "A growing library for Do Stuff & Have Fun videos from the connected YouTube channels.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-video-preview:-1" />
    <link rel="canonical" href="https://dostuffandhavefun.com/videos/" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://dostuffandhavefun.com/videos/" />
    <meta property="og:image" content="https://dostuffandhavefun.com/assets/play-lab-hero.png" />
  </head>
  <body class="video-site">
    <header class="topbar" aria-label="Site header">
      <a class="brand wordmark" href="/" aria-label="Do Stuff and Have Fun home">
        <span>Do Stuff</span>
        <strong>Videos</strong>
      </a>
      <nav aria-label="Main navigation">
        <a href="/#videos">Latest</a>
        <a href="/#channels">Channels</a>
        <a href="/videos/">All Videos</a>
      </nav>
    </header>

    <main>
      <section class="topic-hero">
        <div class="topic-hero-inner">
          <p class="eyebrow">Video library</p>
          <h1>Videos Built For Curious Clicks</h1>
          <p>
            {hasConnectedVideos
              ? "The newest connected YouTube uploads appear here automatically."
              : "Once the YouTube channels are connected, new uploads can appear here automatically."}
          </p>
          <a class="button primary" href="/">Back to latest</a>
        </div>
      </section>

      <section class="section">
        <div class="video-grid">
          {videos.map((video) => (
            <article class="video-card">
              <a href={video.isLive && video.id ? `/videos/${video.id}/` : video.url} aria-label={`Open ${video.title}`}>
                <img src={video.thumbnail} alt="" loading="lazy" />
                <span class="play">{video.status ?? "Watch"}</span>
              </a>
              <div class="video-card-copy">
                <p>{video.channel}</p>
                <h3>{video.title}</h3>
                <p>{video.description}</p>
                <div class="tags">
                  {video.keywords.map((keyword) => <span>{keyword}</span>)}
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>
    </main>

    <footer>
      <p>Do Stuff & Have Fun. Latest connected videos, updated from YouTube.</p>
    </footer>
  </body>
</html>
