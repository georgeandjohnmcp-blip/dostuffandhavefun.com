---
import { buildFeaturedVideos } from "../../data/site.js";
import generatedVideos from "../../data/videos.generated.json";
import "../../styles/global.css";

const videos = buildFeaturedVideos(generatedVideos);
const hasConnectedVideos = Array.isArray(generatedVideos) && generatedVideos.length > 0;
const pageTitle = "Video Library | Do Stuff & Have Fun";
const pageDescription =
  "A growing library for Do Stuff & Have Fun videos, kid-friendly challenges, Shorts, crafts, and experiments.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-video-preview:-1" />
    <link rel="canonical" href="https://dostuffandhavefun.com/videos/" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://dostuffandhavefun.com/videos/" />
    <meta property="og:image" content="https://dostuffandhavefun.com/assets/play-lab-hero.png" />
  </head>
  <body>
    <header class="topbar" aria-label="Site header">
      <a class="brand" href="/" aria-label="Do Stuff and Have Fun home">
        <img src="/assets/do-stuff-logo.png" alt="Do Stuff & Have Fun logo" />
      </a>
      <nav aria-label="Main navigation">
        <a href="/videos/">Videos</a>
        <a href="/games/pong/">Game</a>
        <a href="/#channels">Channels</a>
        <a href="/#growth">Growth Engine</a>
      </nav>
    </header>

    <main>
      <section class="topic-hero">
        <div class="topic-hero-inner">
          <p class="eyebrow">Video library</p>
          <h1>Videos Built For Curious Clicks</h1>
          <p>
            {hasConnectedVideos
              ? "The newest connected YouTube uploads appear here automatically, with search-friendly summaries and watch paths."
              : "This is the launch-ready video library. Once the real YouTube channels are connected, new uploads can appear here automatically."}
          </p>
          <a class="button primary" href="/#youtube-connection">Connect real channels</a>
        </div>
      </section>

      <section class="section">
        <div class="video-grid">
          {videos.map((video) => (
            <article class="video-card">
              <a href={video.isLive && video.id ? `/videos/${video.id}/` : video.url} aria-label={`Open ${video.title}`}>
                <img src={video.thumbnail} alt="" loading="lazy" />
                <span class="play">{video.status ?? "Watch"}</span>
              </a>
              <div class="video-card-copy">
                <p>{video.channel}</p>
                <h3>{video.title}</h3>
                <p>{video.description}</p>
                <div class="tags">
                  {video.keywords.map((keyword) => <span>{keyword}</span>)}
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>
    </main>

    <footer>
      <img src="/assets/do-stuff-logo.png" alt="" />
      <p>Do Stuff & Have Fun is being built as a playful, family-friendly video hub.</p>
    </footer>
  </body>
</html>
