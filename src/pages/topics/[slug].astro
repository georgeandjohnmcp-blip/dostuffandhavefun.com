---
import { topicHubs } from "../../data/site.js";
import "../../styles/global.css";

export function getStaticPaths() {
  return topicHubs.map((topic) => ({
    params: { slug: topic.slug },
    props: { topic }
  }));
}

const { topic } = Astro.props;
const pageTitle = `${topic.title} | Do Stuff & Have Fun`;
const pageDescription = topic.answer;

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: topic.questions.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer
    }
  }))
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <link rel="canonical" href={`https://dostuffandhavefun.com/topics/${topic.slug}/`} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={`https://dostuffandhavefun.com/topics/${topic.slug}/`} />
    <meta property="og:image" content="https://dostuffandhavefun.com/assets/play-lab-hero.png" />
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </head>
  <body>
    <header class="topbar" aria-label="Site header">
      <a class="brand" href="/" aria-label="Do Stuff and Have Fun home">
        <img src="/assets/do-stuff-logo.png" alt="Do Stuff & Have Fun logo" />
      </a>
      <nav aria-label="Main navigation">
        <a href="/#videos">Videos</a>
        <a href="/#channels">Channels</a>
        <a href="/#growth">Growth Engine</a>
      </nav>
    </header>

    <main>
      <section class="topic-hero">
        <div class="topic-hero-inner">
          <p class="eyebrow">Topic hub</p>
          <h1>{topic.title}</h1>
          <p>{topic.intro}</p>
          <a class="button primary" href="/#youtube-connection">Connect real videos</a>
        </div>
      </section>

      <section class="section">
        <div class="topic-content">
          <article class="topic-panel">
            <p class="eyebrow">Watch path</p>
            <h2>How this hub should grow</h2>
            <ol>
              {topic.watchPlan.map((item) => <li>{item}</li>)}
            </ol>
          </article>

          <aside class="topic-panel">
            <p class="eyebrow">Search phrases</p>
            <h2>What this page targets</h2>
            <div class="tags">
              {topic.keywords.map((keyword) => <span>{keyword}</span>)}
            </div>
          </aside>
        </div>
      </section>

      <section class="section">
        <div class="section-heading">
          <p class="eyebrow">Helpful answers</p>
          <h2>Questions this hub can win</h2>
        </div>
        <div class="faq-stack">
          {topic.questions.map((item) => (
            <article>
              <h3>{item.question}</h3>
              <p>{item.answer}</p>
            </article>
          ))}
        </div>
      </section>
    </main>

    <footer>
      <img src="/assets/do-stuff-logo.png" alt="" />
      <p>Do Stuff & Have Fun is being built as a playful, family-friendly video hub.</p>
    </footer>
  </body>
</html>
