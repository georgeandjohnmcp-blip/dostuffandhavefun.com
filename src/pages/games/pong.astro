---
import "../../styles/global.css";

const pageTitle = "Pong Game | Do Stuff & Have Fun";
const pageDescription = "A fast, fun browser Pong game for Do Stuff & Have Fun.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <link rel="canonical" href="https://dostuffandhavefun.com/games/pong/" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://dostuffandhavefun.com/games/pong/" />
    <meta property="og:image" content="https://dostuffandhavefun.com/assets/play-lab-hero.png" />
  </head>
  <body>
    <header class="topbar" aria-label="Site header">
      <a class="brand" href="/" aria-label="Do Stuff and Have Fun home">
        <img src="/assets/do-stuff-logo.png" alt="Do Stuff & Have Fun logo" />
      </a>
      <nav aria-label="Main navigation">
        <a href="/videos/">Videos</a>
        <a href="/games/pong/">Game</a>
        <a href="/#channels">Channels</a>
        <a href="/#growth">Growth</a>
      </nav>
    </header>

    <main>
      <section class="topic-hero">
        <div class="topic-hero-inner">
          <p class="eyebrow">Mini game</p>
          <h1>Pong</h1>
          <p>Keep the ball flying, score seven points, and protect the Do Stuff & Have Fun side.</p>
        </div>
      </section>

      <section class="game-shell">
        <div class="game-layout">
          <div class="game-frame">
            <div class="game-hud" aria-label="Game score">
              <div class="game-meter"><span>You</span><strong id="playerScore">0</strong></div>
              <div class="game-meter"><span>Round</span><strong id="roundStatus">Ready</strong></div>
              <div class="game-meter"><span>Computer</span><strong id="cpuScore">0</strong></div>
            </div>
            <div class="game-canvas-wrap">
              <canvas id="game" width="960" height="540" aria-label="Pong game board"></canvas>
              <div class="game-start" id="gameStart">
                <div class="game-start-panel">
                  <p class="eyebrow">Ready?</p>
                  <h2>Play Pong</h2>
                  <p>Move your paddle and bounce the ball past the computer.</p>
                  <button id="startButton" type="button">Start</button>
                </div>
              </div>
            </div>
          </div>

          <aside class="game-side">
            <div class="game-card">
              <p class="eyebrow">Goal</p>
              <h2>First to 7 wins</h2>
              <p>The ball gets quicker after clean hits, so stay sharp.</p>
            </div>
            <div class="game-card">
              <p class="eyebrow">Controls</p>
              <div class="touch-controls">
                <button id="upButton" type="button">Up</button>
                <button id="downButton" type="button">Down</button>
              </div>
            </div>
          </aside>
        </div>
      </section>
    </main>

    <footer>
      <img src="/assets/do-stuff-logo.png" alt="" />
      <p>Do Stuff & Have Fun is being built as a playful, family-friendly video hub.</p>
    </footer>

    <script>
      const canvas = document.getElementById("game");
      const ctx = canvas.getContext("2d");
      const playerScoreEl = document.getElementById("playerScore");
      const cpuScoreEl = document.getElementById("cpuScore");
      const roundStatusEl = document.getElementById("roundStatus");
      const startOverlay = document.getElementById("gameStart");
      const startButton = document.getElementById("startButton");
      const upButton = document.getElementById("upButton");
      const downButton = document.getElementById("downButton");

      const state = {
        running: false,
        keys: new Set(),
        playerScore: 0,
        cpuScore: 0,
        player: { x: 42, y: 210, w: 24, h: 120 },
        cpu: { x: 894, y: 210, w: 24, h: 120 },
        ball: { x: 480, y: 270, r: 16, vx: 6, vy: 3.2 }
      };

      function syncHud(status = "Play") {
        playerScoreEl.textContent = state.playerScore;
        cpuScoreEl.textContent = state.cpuScore;
        roundStatusEl.textContent = status;
      }

      function resetBall(direction = 1) {
        state.ball.x = canvas.width / 2;
        state.ball.y = canvas.height / 2;
        state.ball.vx = direction * 6;
        state.ball.vy = (Math.random() > 0.5 ? 1 : -1) * (2.4 + Math.random() * 2.4);
      }

      function resetGame() {
        state.running = true;
        state.playerScore = 0;
        state.cpuScore = 0;
        state.player.y = 210;
        state.cpu.y = 210;
        resetBall(Math.random() > 0.5 ? 1 : -1);
        startButton.textContent = "Start";
        startOverlay.hidden = true;
        syncHud("Play");
        requestAnimationFrame(tick);
      }

      function endGame(message) {
        state.running = false;
        syncHud(message);
        startButton.textContent = "Play Again";
        startOverlay.hidden = false;
      }

      function drawBackground() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        ctx.fillStyle = "rgba(255, 250, 240, 0.86)";
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        ctx.strokeStyle = "rgba(16, 35, 63, 0.25)";
        ctx.lineWidth = 8;
        ctx.setLineDash([18, 18]);
        ctx.beginPath();
        ctx.moveTo(canvas.width / 2, 26);
        ctx.lineTo(canvas.width / 2, canvas.height - 26);
        ctx.stroke();
        ctx.setLineDash([]);
      }

      function drawPaddle(paddle, color) {
        ctx.fillStyle = color;
        ctx.strokeStyle = "#10233f";
        ctx.lineWidth = 6;
        ctx.beginPath();
        ctx.roundRect(paddle.x, paddle.y, paddle.w, paddle.h, 12);
        ctx.fill();
        ctx.stroke();
      }

      function drawBall() {
        const b = state.ball;
        ctx.fillStyle = "#ffd23f";
        ctx.strokeStyle = "#10233f";
        ctx.lineWidth = 6;
        ctx.beginPath();
        ctx.arc(b.x, b.y, b.r, 0, Math.PI * 2);
        ctx.fill();
        ctx.stroke();
      }

      function clampPaddle(paddle) {
        paddle.y = Math.max(18, Math.min(canvas.height - paddle.h - 18, paddle.y));
      }

      function paddleHit(paddle) {
        const b = state.ball;
        return b.x + b.r > paddle.x && b.x - b.r < paddle.x + paddle.w && b.y + b.r > paddle.y && b.y - b.r < paddle.y + paddle.h;
      }

      function bounceFrom(paddle, direction) {
        const b = state.ball;
        const hit = (b.y - (paddle.y + paddle.h / 2)) / (paddle.h / 2);
        b.vx = direction * Math.min(11, Math.abs(b.vx) + 0.55);
        b.vy = hit * 7;
        b.x = direction > 0 ? paddle.x + paddle.w + b.r : paddle.x - b.r;
      }

      function movePlayer() {
        const up = state.keys.has("ArrowUp") || state.keys.has("w") || state.keys.has("W");
        const down = state.keys.has("ArrowDown") || state.keys.has("s") || state.keys.has("S");
        if (up) state.player.y -= 8.5;
        if (down) state.player.y += 8.5;
        clampPaddle(state.player);
      }

      function moveCpu() {
        const target = state.ball.y - state.cpu.h / 2;
        state.cpu.y += (target - state.cpu.y) * 0.075;
        clampPaddle(state.cpu);
      }

      function scorePoint(playerScored) {
        if (playerScored) {
          state.playerScore += 1;
          syncHud("Nice");
          resetBall(-1);
        } else {
          state.cpuScore += 1;
          syncHud("Keep going");
          resetBall(1);
        }

        if (state.playerScore >= 7) endGame("You win");
        if (state.cpuScore >= 7) endGame("Try again");
      }

      function tick() {
        if (!state.running) return;
        movePlayer();
        moveCpu();

        const b = state.ball;
        b.x += b.vx;
        b.y += b.vy;

        if (b.y - b.r < 14 || b.y + b.r > canvas.height - 14) {
          b.vy *= -1;
          b.y = Math.max(14 + b.r, Math.min(canvas.height - 14 - b.r, b.y));
        }

        if (b.vx < 0 && paddleHit(state.player)) bounceFrom(state.player, 1);
        if (b.vx > 0 && paddleHit(state.cpu)) bounceFrom(state.cpu, -1);

        if (b.x + b.r < 0) scorePoint(false);
        if (b.x - b.r > canvas.width) scorePoint(true);

        drawBackground();
        drawPaddle(state.player, "#25c7d9");
        drawPaddle(state.cpu, "#ff5b4a");
        drawBall();

        if (state.running) requestAnimationFrame(tick);
      }

      startButton.addEventListener("click", resetGame);
      window.addEventListener("keydown", (event) => state.keys.add(event.key));
      window.addEventListener("keyup", (event) => state.keys.delete(event.key));
      upButton.addEventListener("pointerdown", () => state.keys.add("ArrowUp"));
      upButton.addEventListener("pointerup", () => state.keys.delete("ArrowUp"));
      upButton.addEventListener("pointerleave", () => state.keys.delete("ArrowUp"));
      downButton.addEventListener("pointerdown", () => state.keys.add("ArrowDown"));
      downButton.addEventListener("pointerup", () => state.keys.delete("ArrowDown"));
      downButton.addEventListener("pointerleave", () => state.keys.delete("ArrowDown"));
      canvas.addEventListener("pointermove", (event) => {
        const rect = canvas.getBoundingClientRect();
        const y = ((event.clientY - rect.top) / rect.height) * canvas.height;
        state.player.y = y - state.player.h / 2;
        clampPaddle(state.player);
      });

      syncHud("Ready");
      drawBackground();
      drawPaddle(state.player, "#25c7d9");
      drawPaddle(state.cpu, "#ff5b4a");
      drawBall();
    </script>
  </body>
</html>
