---
import { channels, buildFeaturedVideos } from "../data/site.js";
import generatedVideos from "../data/videos.generated.json";
import { tracking } from "../data/tracking.js";
import "../styles/global.css";

const pageTitle = "Do Stuff & Have Fun | Videos";
const pageDescription =
  "Watch the latest videos from the connected Do Stuff & Have Fun YouTube channels.";
const videos = buildFeaturedVideos(generatedVideos);
const connectedVideoCount = Array.isArray(generatedVideos) ? generatedVideos.length : 0;

const absoluteImageUrl = (url) => (url?.startsWith("http") ? url : `https://dostuffandhavefun.com${url}`);
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      name: "Do Stuff & Have Fun",
      url: "https://dostuffandhavefun.com"
    },
    {
      "@type": "ItemList",
      name: "Latest videos",
      itemListElement: videos.map((video, index) => ({
        "@type": "ListItem",
        position: index + 1,
        name: video.title,
        url: video.isLive && video.id ? `https://dostuffandhavefun.com/videos/${video.id}/` : video.url
      }))
    },
    ...videos.filter((video) => video.isLive).map((video) => ({
      "@type": "VideoObject",
      name: video.title,
      description: video.description,
      thumbnailUrl: [absoluteImageUrl(video.thumbnail)],
      uploadDate: video.published || "2026-06-14",
      embedUrl: video.url,
      publisher: {
        "@type": "Organization",
        name: "Do Stuff & Have Fun"
      }
    }))
  ]
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-video-preview:-1" />
    <link rel="canonical" href="https://dostuffandhavefun.com/" />
    <meta property="og:title" content="Do Stuff & Have Fun Videos" />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://dostuffandhavefun.com/" />
    <meta property="og:image" content={videos[0]?.thumbnail || "https://dostuffandhavefun.com/assets/play-lab-hero.png"} />
    <meta name="twitter:card" content="summary_large_image" />
    {tracking.googleSiteVerification && <meta name="google-site-verification" content={tracking.googleSiteVerification} />}
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    {tracking.ga4MeasurementId && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${tracking.ga4MeasurementId}`}></script>
        <script
          set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${tracking.ga4MeasurementId}',{send_page_view:true});`}
        />
      </>
    )}
  </head>
  <body class="video-site">
    <header class="topbar" aria-label="Site header">
      <a class="brand wordmark" href="/" aria-label="Do Stuff and Have Fun home">
        <span>Do Stuff</span>
        <strong>Videos</strong>
      </a>
      <nav aria-label="Main navigation">
        <a href="#videos">Latest</a>
        <a href="#channels">Channels</a>
        <a href="/videos/">All Videos</a>
      </nav>
    </header>

    <main>
      <section class="video-hero">
        <div class="video-hero-copy">
          <p class="eyebrow">Latest uploads</p>
          <h1>Your videos, all in one place.</h1>
          <p class="lede">
            {connectedVideoCount} videos from the connected YouTube channels, with fresh pages for watching,
            sharing, and search.
          </p>
          <div class="hero-actions">
            <a class="button primary" href="#videos">Watch latest</a>
            <a class="button secondary" href="/videos/">Open library</a>
          </div>
        </div>
        <div class="hero-video-stack" aria-label="Featured video thumbnails">
          {videos.slice(0, 3).map((video) => (
            <a href={video.isLive && video.id ? `/videos/${video.id}/` : video.url}>
              <img src={video.thumbnail} alt="" loading="eager" />
              <span>{video.title}</span>
            </a>
          ))}
        </div>
      </section>

      <section id="videos" class="section">
        <div class="section-heading">
          <p class="eyebrow">Watch next</p>
          <h2>Latest videos</h2>
          <p>Only real uploads from the connected channels are shown here.</p>
        </div>
        <div class="video-grid">
          {videos.map((video) => (
            <article class="video-card">
              <a href={video.isLive && video.id ? `/videos/${video.id}/` : video.url} aria-label={`Open ${video.title}`}>
                <img src={video.thumbnail} alt="" loading="lazy" />
                <span class="play">{video.status ?? "Watch"}</span>
              </a>
              <div class="video-card-copy">
                <p>{video.channel}</p>
                <h3>{video.title}</h3>
                <p>{video.description}</p>
                <div class="tags">
                  {video.keywords.map((keyword) => <span>{keyword}</span>)}
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section id="channels" class="section channel-band">
        <div class="section-heading">
          <p class="eyebrow">Channels</p>
          <h2>Connected YouTube channels</h2>
          <p>These are the channels currently feeding the site.</p>
        </div>
        <div class="channel-grid">
          {channels.map((channel) => (
            <article class={`channel-card ${channel.color}`}>
              <span>{channel.theme}</span>
              <h3>{channel.name}</h3>
              <p>{channel.handle}</p>
              <p>{channel.description}</p>
              <a href={channel.url}>Visit channel</a>
            </article>
          ))}
        </div>
      </section>
    </main>

    <footer>
      <p>Do Stuff & Have Fun. Latest connected videos, updated from YouTube.</p>
    </footer>
  </body>
</html>
